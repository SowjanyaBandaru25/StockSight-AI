rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-All Deny Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 128
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 64))
        && data.createdAt == request.time;
    }

    function isValidPreference(data) {
      return data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
        && data.watchlist is list && data.watchlist.size() <= 20
        && (data.watchlist.size() == 0 || data.watchlist[0] is string)
        && data.riskTolerance is string && data.riskTolerance.size() <= 32
        && (data.riskTolerance == 'low' || data.riskTolerance == 'medium' || data.riskTolerance == 'high')
        && data.updatedAt == request.time;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isVerified() && request.auth.uid == userId;
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming()) && incoming().keys().hasAll(['uid', 'email', 'createdAt']) && incoming().keys().size() <= 4;
      allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming()) && incoming().uid == existing().uid && incoming().email == existing().email && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
      allow delete: if false;
    }

    match /preferences/{userId} {
      allow get: if isVerified() && request.auth.uid == userId;
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidPreference(incoming()) && incoming().keys().hasAll(['userId', 'watchlist', 'riskTolerance', 'updatedAt']) && incoming().keys().size() == 4;
      allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidPreference(incoming()) && incoming().userId == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['watchlist', 'riskTolerance', 'updatedAt']);
      allow delete: if isVerified() && isValidId(userId) && userId == request.auth.uid;
    }
  }
}
